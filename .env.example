# Copy to .env for local overrides. All keys are prefixed DATAFORGE_.

DATAFORGE_ENVIRONMENT=local
DATAFORGE_DEBUG=true
DATAFORGE_LOG_LEVEL=INFO
# Pretty console logs locally; set true for JSON in deployed envs.
DATAFORGE_LOG_JSON=false

DATAFORGE_HOST=0.0.0.0
DATAFORGE_PORT=8000

# Backing services (match docker-compose service names inside the network).
DATAFORGE_POSTGRES_DSN=postgresql+asyncpg://dataforge:dataforge@postgres:5432/dataforge
DATAFORGE_REDIS_URL=redis://redis:6379/0
DATAFORGE_QDRANT_URL=http://qdrant:6333

# Observability
DATAFORGE_METRICS_ENABLED=true
DATAFORGE_TRACING_ENABLED=true
# Leave empty for a local no-op tracer; set to an OTLP collector when available.
DATAFORGE_OTEL_EXPORTER_OTLP_ENDPOINT=

# LLM — null provider is the safe default and needs no credentials.
# Switch to anthropic / openai / ollama as needed.
DATAFORGE_LLM_PROVIDER=null
DATAFORGE_LLM_MODEL=claude-sonnet-4-6
DATAFORGE_ANTHROPIC_API_KEY=
DATAFORGE_OPENAI_API_KEY=
DATAFORGE_OLLAMA_BASE_URL=http://localhost:11434
DATAFORGE_LLM_TIMEOUT_SECONDS=60
DATAFORGE_LLM_MAX_RETRIES=3
DATAFORGE_LLM_MAX_OUTPUT_TOKENS=4096
DATAFORGE_LLM_CIRCUIT_FAILURE_THRESHOLD=5
DATAFORGE_LLM_CIRCUIT_COOLDOWN_SECONDS=30
DATAFORGE_LLM_DAILY_TOKEN_BUDGET=1000000

# RAG embedder — hashing (default, zero-dep) or semantic (bge via fastembed).
DATAFORGE_RAG_EMBEDDER=hashing
DATAFORGE_RAG_EMBEDDER_MODEL=BAAI/bge-small-en-v1.5
# Optional: where to cache the model file (default: ~/.cache/fastembed).
DATAFORGE_RAG_EMBEDDER_CACHE_DIR=

# ML anomaly detectors. Off by default (rule-based detectors only).
DATAFORGE_ML_DETECTORS_ENABLED=false
DATAFORGE_ML_DETECTOR_ISOLATION_FOREST=true
DATAFORGE_ML_DETECTOR_TIMESERIES=true
DATAFORGE_ML_DETECTOR_LOG_TEMPLATE=true
DATAFORGE_ML_DETECTOR_HISTORY_LIMIT=100

# GitHub remediation pipeline. Token enables push + PR; without it,
# only --dry-run mode works (still useful for demos).
DATAFORGE_GITHUB_TOKEN=
DATAFORGE_GITHUB_API_URL=https://api.github.com
DATAFORGE_GIT_USER_NAME=DataForge Bot
DATAFORGE_GIT_USER_EMAIL=bot@dataforge.ai
